<Window x:Class="RouteForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RouteForge" Height="650" Width="980"
        MinHeight="560" MinWidth="850"
        Background="#0B0E14" Foreground="#EDF2F7">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#263042"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#151B26"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#344158"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="RouteForge" FontSize="31" FontWeight="Bold"/>
            <TextBlock Text="Free Windows game-route tester and WireGuard relay launcher"
                       Foreground="#98A6BA" Margin="0,3,0,14"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#111722" CornerRadius="10" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TargetBox"
                         Text="1.1.1.1, 8.8.8.8"
                         ToolTip="Comma-separated IP addresses or hostnames"/>
                <Button Grid.Column="1" x:Name="TestButton"
                        Content="Test routes" Click="TestButton_Click"/>
                <Button Grid.Column="2" Content="Add relay profile"
                        Click="AddRelayButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="#111722" CornerRadius="10" Padding="10" Margin="0,0,7,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Connection measurements"
                               FontSize="18" FontWeight="SemiBold" Margin="6"/>
                    <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False"
                              IsReadOnly="True" HeadersVisibility="Column"
                              Background="#111722" Foreground="White"
                              RowBackground="#151B26" AlternatingRowBackground="#192130"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="*"/>
                            <DataGridTextColumn Header="Avg ms" Binding="{Binding AverageMs}" Width="90"/>
                            <DataGridTextColumn Header="Jitter" Binding="{Binding JitterMs}" Width="90"/>
                            <DataGridTextColumn Header="Loss %" Binding="{Binding LossPercent}" Width="90"/>
                            <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="#111722" CornerRadius="10" Padding="14" Margin="7,0,0,0">
                <StackPanel>
                    <TextBlock Text="Relay profiles" FontSize="18" FontWeight="SemiBold"/>
                    <ListBox x:Name="RelayList" Height="245" Margin="0,10"
                             Background="#151B26" Foreground="White"
                             DisplayMemberPath="Name"/>
                    <Button Content="Connect selected relay" Click="ConnectRelayButton_Click"/>
                    <Button Content="Disconnect selected relay" Click="DisconnectRelayButton_Click"/>
                    <Separator Margin="0,12"/>
                    <TextBlock Text="Game executable"/>
                    <TextBox x:Name="GamePathBox" Text="C:\Path\To\Game.exe"/>
                    <Button Content="Launch game" Click="LaunchGameButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#111722" CornerRadius="8" Padding="10">
            <TextBlock x:Name="StatusText" Text="Ready. Test your normal connection first."
                       Foreground="#B7C2D3" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>
